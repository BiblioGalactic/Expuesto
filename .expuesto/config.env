# Configuración por defecto para utilidades bash de Expuesto.
# Estos valores son usados por tests e2e y pueden sobreescribirse
# mediante variables de entorno antes de ejecutar scripts.

LLAMA_CTX_SIZE="${LLAMA_CTX_SIZE:-4096}"
LOG_MAX_LINES="${LOG_MAX_LINES:-10000}"
LLAMA_THREADS="${LLAMA_THREADS:-6}"

export LLAMA_CTX_SIZE
export LOG_MAX_LINES
export LLAMA_THREADS
